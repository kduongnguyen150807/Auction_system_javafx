<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<VBox stylesheets="@../css/Menu.css"
      prefHeight="768" prefWidth="1024" minWidth="1024" minHeight="768"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" >
    <children>
        <!--Scroll Pane-->
        <ScrollPane styleClass="ScrollPane" minHeight="768.0" minWidth="1024.0" fitToWidth="true">
            <content>
                <VBox spacing="10">
                    <children>
                        <!--Logo-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0" minHeight="100.0" prefHeight="100.0"
                              style="-fx-background-color: black;">
                            <children>
                                <Label text="BIDDING" textFill="White">
                                    <font><Font name="Consolas Bold" size="40.0" /></font>
                                </Label>
                                <HBox style="-fx-background-color: orange; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: orange;"
                                      alignment="CENTER" prefHeight="35" maxHeight="35" prefWidth="50">
                                    <Label text="88" textFill="Black">
                                        <font>
                                            <Font name="Consolas Bold" size="30.0" />
                                        </font>
                                    </Label>
                                </HBox>
                            </children>
                            <padding><Insets left="20"/> </padding>
                        </HBox>
                        <!--Banner-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0"
                              minHeight="100.0" prefHeight="100.0" style="-fx-background-color: orange;" spacing="10">
                            <children>
                                <ImageView fitHeight="80.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/hutao_money.gif" /></image>
                                </ImageView>
                                <!-- Trang chu button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Trang chủ">
                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <!-- Ho so button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Hồ sơ">
                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                            <padding><Insets left="20.0" /></padding>
                        </HBox>
                        <VBox style="-fx-background-color: black;" minHeight="0">
                            <children>
                                <HBox alignment="CENTER" prefWidth="1024">
                                    <children>
                                        <ImageView fitWidth="1000" preserveRatio="false">
                                            <image><Image url="@../images/cat2.jpeg"/></image>
                                        </ImageView>
                                    </children>
                                </HBox>
                                <!-- Ongoing Bnind-->
                                <VBox spacing="20" prefHeight="200">
                                    <children>
                                        <!--Ten  Muc Luc -->
                                        <Label text="Ongoing Bind" textFill="WHITE">
                                            <font><Font name="Consolas Bold" size="40.0" /></font>
                                            <VBox.margin><Insets left="45.0" top="30.0" /></VBox.margin>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="45.0" right="45.0" /></VBox.margin>
                                        </Separator>
                                        <!-- hop chua san pham dau gia-->
                                        <HBox spacing="20" styleClass="BindLine" >
                                            <children>
                                                <!-- san pham dau gia duoc hien thi trong VBOX -->
                                                <VBox styleClass="BindLineItem" alignment="TOP_CENTER">
                                                    <children>
                                                        <!-- image holder -->
                                                        <ImageView fitWidth="99" fitHeight="99">
                                                            <image><Image url="@../images/hutao_money.gif"/> </image>
                                                        </ImageView>
                                                        <!-- Name holdere -->
                                                        <Label text="Item N/A" textFill="White">
                                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                                <VBox styleClass="BindLineItem">
                                                    <children>
                                                        <ImageView fitWidth="99" fitHeight="99">
                                                            <image><Image url="@../images/cat2.jpeg"/> </image>
                                                        </ImageView>
                                                        <Label text="Item N/A" textFill="White">
                                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                            </children>
                                            <padding><Insets left="15.0" /></padding>
                                        </HBox>
                                    </children>
                                </VBox>
                                <!-- Upcoming Bind-->
                                <VBox spacing="20" prefHeight="500">
                                    <children>
                                        <Label text="Upcoming Bind" textFill="WHITE">
                                            <font><Font name="Consolas Bold" size="40.0" /></font>
                                            <VBox.margin><Insets left="45.0" top="30.0" /></VBox.margin>
                                        </Label>

                                        <Separator>
                                            <VBox.margin><Insets left="45.0" right="45.0" /></VBox.margin>
                                        </Separator>

                                        <HBox spacing="20" styleClass="BindLine" >
                                            <children>
                                                <!-- san pham dau gia duoc hien thi trong VBOX -->
                                                <VBox styleClass="BindLineItem" alignment="TOP_CENTER">
                                                    <children>
                                                        <!-- image holder -->
                                                        <ImageView fitWidth="99" fitHeight="99">
                                                            <image><Image url="@../images/hutao_money.gif"/> </image>
                                                        </ImageView>
                                                        <!-- Name holdere -->
                                                        <Label text="Item N/A" textFill="White">
                                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                                <VBox styleClass="BindLineItem">
                                                    <children>
                                                        <ImageView fitWidth="99" fitHeight="99">
                                                            <image><Image url="@../images/cat2.jpeg"/> </image>
                                                        </ImageView>
                                                        <Label text="Item N/A" textFill="White">
                                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                    <padding><Insets left="15.0" /></padding>
                                </VBox>
                            </children>
                        </VBox>
                        <VBox alignment="TOP_CENTER" spacing="20"
                              style="-fx-background-color: orange; -fx-padding: 20;"
                              minWidth="1000" minHeight="300">
                            <Label text="About Us"
                                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: black;" />
                        </VBox>
                    </children>
                </VBox>

            </content>
        </ScrollPane>
    </children>
</VBox>