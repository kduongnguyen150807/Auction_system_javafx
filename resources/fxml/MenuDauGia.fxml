<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<VBox stylesheets="@../css/ManHinhDauGia.css"
      prefHeight="768" prefWidth="1024" minWidth="1024" minHeight="768"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" >
    <children>
        <!--Scroll Pane-->
        <ScrollPane styleClass="ScrollPane" minHeight="768.0" minWidth="1024.0" fitToWidth="true">
            <content>
                <VBox alignment="CENTER" spacing="10">
                    <children>
                        <!--Logo-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0" minHeight="100.0" prefHeight="100.0" style="-fx-background-color: #000000;">
                            <children>
                                <Label text="BIDDING" textFill="White">
                                    <font><Font name="Consolas Bold" size="40.0" /></font>
                                </Label>
                                <HBox style="-fx-background-color: orange; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: orange;"
                                      alignment="CENTER" prefHeight="35" maxHeight="35" prefWidth="50">
                                    <Label text="88" textFill="Black">
                                        <font>
                                            <Font name="Consolas Bold" size="30.0" />
                                        </font>
                                    </Label>
                                </HBox>
                            </children>
                            <padding><Insets left="20"/> </padding>
                        </HBox>
                        <!--Banner-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0"
                              minHeight="100.0" prefHeight="100.0" style="-fx-background-color: orange;" spacing="10">
                            <children>
                                <ImageView fitHeight="80.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/hutao_money.gif" /></image>
                                </ImageView>
                                <!-- Trang chu button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Trang chủ">
                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <!-- Ho so button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Hồ sơ">
                                            <font><Font name="Consolas Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                            <padding><Insets left="20.0" /></padding>
                        </HBox>
                        <!-- thong tin san pham-->
                        <HBox alignment="TOP_LEFT" minHeight="1000" prefHeight="1000" maxHeight="1000"
                              minWidth="200" prefWidth="700" maxWidth="700"
                              style="-fx-background-color: black;" spacing="20">
                            <children>
                                <!--anh-->
                                <ImageView fitHeight="500" fitWidth="400" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/cat2.jpeg"/></image>
                                </ImageView>

                                <!-- thong tin co ban-->
                                <VBox alignment="TOP_LEFT" style="-fx-background-color: black"
                                      minHeight="500" prefHeight="500" maxHeight="500"
                                      minWidth="310" prefWidth="200" maxWidth="200">
                                    <children>
                                        <!--Name-->
                                        <Label text="Tên: N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="20.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="0" /></VBox.margin>
                                        </Separator>
                                        <!-- Starting price-->
                                        <Label text="Giá khởi điểm : N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="20.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="0" /></VBox.margin>
                                        </Separator>
                                        <!-- Current price-->
                                        <Label text="Giá hiện tại : N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="20.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="0" /></VBox.margin>
                                        </Separator>
                                        <!-- Id -->
                                        <Label text="Mã sản phẩm : N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="20.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="0" bottom="20"/></VBox.margin>
                                        </Separator>

                                        <!-- Time related-->
                                        <VBox styleClass="TimeBox" alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="Start time: N/A" textFill="Black">
                                                    <font><Font name="Consolas Bold" size="20.0" /></font>
                                                </Label>
                                                <Label text="End time: N/A" textFill="Black">
                                                    <font><Font name="Consolas Bold" size="20.0" /></font>
                                                </Label>
                                                <Button text="Đăng ký tham gia đấu giá" textFill="White"
                                                        prefHeight="50" prefWidth="200"
                                                        styleClass="DangKyButton">
                                                </Button>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <VBox alignment="TOP_CENTER" spacing="20"
                          style="-fx-background-color: orange; -fx-padding: 20;"
                          minWidth="1000" minHeight="300">
                        <Label text="About Us"
                               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: black;" />
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>