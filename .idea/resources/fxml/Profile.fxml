<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<VBox stylesheets="@../css/ManHinhDauGia.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" >
    <children>
        <!--Banner-->
        <HBox alignment="CENTER_LEFT" maxHeight="100.0" minHeight="100.0" prefHeight="100.0" style="-fx-background-color: orange;">
            <children>
                <ImageView fitHeight="80.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/hutao_money.gif" /></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="Bidding88">
                            <font><Font name="Consolas Bold" size="24.0" /></font>
                        </Label>
                        <Label text="Online Auctions">
                            <font><Font name="Consolas Bold" size="14.0" /></font>
                        </Label>
                    </children>
                    <padding><Insets left="15.0" /></padding>
                </VBox>
                <!-- Trang chu button -->
                <VBox alignment="CENTER" spacing="15.0" styleClass="TrangChuButton">
                    <children>
                        <Label text="Trang chủ">
                            <font><Font name="Consolas Bold" size="24.0" /></font>
                        </Label>
                        <Label text="^">
                            <font><Font name="Consolas Bold" size="14.0" /></font>
                        </Label>
                    </children>
                </VBox>
                <!-- Ho so button -->
                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                    <children>
                        <Label text="Hồ sơ">
                            <font><Font name="Consolas Bold" size="24.0" /></font>
                        </Label>
                        <Label text="^">
                            <font><Font name="Consolas Bold" size="14.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
            <padding><Insets left="20.0" /></padding>
        </HBox>
        <!--Scroll Pane-->
        <ScrollPane styleClass="ScrollPane" minHeight="768.0" minWidth="1024.0" fitToWidth="true">
            <content>

            </content>
        </ScrollPane>
    </children>
</VBox>