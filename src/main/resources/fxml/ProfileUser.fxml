<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>

<?import javafx.scene.layout.Region?>
<VBox stylesheets="@../css/ProfileUser.css"
      prefHeight="768" prefWidth="1024" minWidth="1024" minHeight="768"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" >
    <children>
        <!--Scroll Pane-->
        <ScrollPane styleClass="ScrollPane" minHeight="768.0" minWidth="1024.0" fitToWidth="true">
            <content>
                <VBox spacing="10">
                    <children>
                        <!--Logo-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0" minHeight="100.0" prefHeight="100.0"
                              style="-fx-background-color: black;">
                            <children>
                                <Label text="BIDDING" textFill="White">
                                    <font><Font name="System Bold" size="40.0" /></font>
                                </Label>
                                <HBox style="-fx-background-color: orange; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: orange;"
                                      alignment="CENTER" prefHeight="35" maxHeight="35" prefWidth="50">
                                    <children>
                                        <Label text="88" textFill="Black">
                                            <font>
                                                <Font name="System Bold" size="30.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER">
                                    <children>
                                        <Label text="AUCTION" textFill="White">
                                            <font><Font name="System Bold" size="40.0" /></font>
                                        </Label>
                                        <Label text="PRO" textFill="orange">
                                            <font><Font name="System Bold" size="40.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                            <padding><Insets left="20"/> </padding>
                        </HBox>
                        <!--Banner-->
                        <HBox alignment="CENTER_LEFT" maxHeight="100.0"
                              minHeight="100.0" prefHeight="100.0" style="-fx-background-color: orange;" spacing="10">
                            <children>
                                <ImageView fitHeight="80.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/hutao_money.gif" /></image>
                                </ImageView>
                                <!-- Trang chu button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Trang chủ">
                                            <font><Font name="System Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <!-- Ho so button -->
                                <VBox alignment="CENTER" spacing="5.0" styleClass="BannerButton">
                                    <children>
                                        <Label text="Hồ sơ">
                                            <font><Font name="System Bold" size="24.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                            <padding><Insets left="20.0" /></padding>
                        </HBox>
                        <!-- khung profile -->
                        <HBox spacing="20">
                            <children>
                                <!-- ben trai la img va muc luc -->
                                <VBox style="-fx-background-color: grey; -fx-border-color: grey; "
                                      prefHeight="500" prefWidth="250" alignment="TOP_CENTER" spacing="20">
                                    <children>
                                        <!-- profile picture holder -->
                                        <ImageView fitHeight="250" fitWidth="200">
                                            <image><Image url="@../images/user_icon.png"/></image>
                                        </ImageView>
                                        <!--muc luc-->
                                        <VBox spacing="10">
                                            <children>
                                                <!-- link dan den muc thong tin co ban -->
                                                <Label text="Thông tin cơ bản" textFill="Blue">
                                                    <font><Font name="Consolas Bold" size="30.0" /></font>
                                                </Label>
                                                <!-- link dan den muc vat so huu -->
                                                <Label text="Tài sản" textFill="Blue">
                                                    <font><Font name="Consolas Bold" size="30.0" /></font>
                                                </Label>
                                            </children>
                                            <padding><Insets left="20"/></padding>
                                        </VBox>
                                    </children>
                                    <padding><Insets top="20"/></padding>
                                </VBox>
                                <!-- ben phai la thong tin cua tung muc luc -->
                                <VBox style="-fx-background-color: black "
                                      prefHeight="500" prefWidth="600" alignment="TOP_LEFT" spacing="10">
                                    <children>
                                        <Label text="Tên người dùng: N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="40.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="45.0" /></VBox.margin>
                                        </Separator>
                                        <Label text="Username: N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="40.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="45.0" /></VBox.margin>
                                        </Separator>
                                        <Label text="Password: N/A" textFill="White">
                                            <font><Font name="Consolas Bold" size="40.0" /></font>
                                        </Label>
                                        <Separator>
                                            <VBox.margin><Insets left="0" right="45.0" /></VBox.margin>
                                        </Separator>
                                    </children>
                                    <padding><Insets top="20" left="20"/></padding>
                                </VBox>
                            </children>
                            <padding><Insets left="75"></Insets></padding>
                        </HBox>
                        <!--about us-->
                        <VBox alignment="TOP_CENTER" spacing="20"
                              style="-fx-background-color: orange; -fx-padding: 20;"
                              minWidth="1000" minHeight="300">
                            <Label text="About Us"
                                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: black;" />
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>