<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="itemRoot" alignment="TOP_CENTER" spacing="8.0" styleClass="KhungItem"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.ui.ItemCard.ItemCardController"
      stylesheets="@/css/itemcard/ItemCard.css"
      prefWidth="222" maxWidth="222" prefHeight="478" maxHeight="478" onMouseClicked="#HandleItemClicked">
    <children>
        <ImageView fitWidth="220" fitHeight="256" fx:id="ImageHolder">
            <image><Image url="@/images/user_icon.png"/></image>
        </ImageView>
        <VBox prefHeight="220" maxHeight="140">
            <children>
                <Label fx:id="ItemName" text="NameHolder" styleClass="MainText"/>
                <Label fx:id="ItemDescription" text="Description" styleClass="SubText"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox prefHeight="64" prefWidth="172" maxWidth="172" maxHeight="64">
                    <children>
                        <VBox prefWidth="87" prefHeight="47" maxHeight="47" maxWidth="87">
                            <Label text="Current BID" styleClass="SubText"><font><Font size="12"/></font></Label>
                            <Label fx:id="Price" text="1000$" styleClass="MainText"><font><Font size="18"/></font></Label>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox prefWidth="87" prefHeight="47" maxHeight="47" maxWidth="87">
                            <Label text="Time Remaining" styleClass="SubText"><font><Font size="12"/></font></Label>
                            <Label fx:id="TimeRemain" text="2d14h" styleClass="MainText"><font><Font size="18"/></font></Label>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding><Insets left="24"/></padding>
        </VBox>
    </children>
</VBox>
