<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Region?>
<HBox xmlns="http://javafx.com/javafx"  fx:id="RootPane"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.ui.SuccessfullyRegister.SuccessfullyRegisterController"
      styleClass="AnnouncementBG"
      alignment="CENTER" stylesheets="@SuccessfullyRegister.css" prefWidth="500" prefHeight="400" maxWidth="500" maxHeight="400">
    <Region HBox.hgrow="ALWAYS"/>
    <children>
        <VBox alignment="CENTER" spacing="10" prefWidth="500" prefHeight="400" maxWidth="500" maxHeight="400">
            <children>
                <!-- v -->
                <VBox alignment="CENTER" maxHeight="80.0" maxWidth="80.0" minHeight="80.0" minWidth="80.0"
                      style="-fx-background-color: #252525; -fx-background-radius: 15;">
                    <children>
                        <Label text="✔" textFill="#f5a64b">
                            <font>
                                <Font size="30.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <!-- success text-->
                <Label text="Success!" textFill="#f5a64b">
                    <font>
                        <Font name="System Bold" size="36.0" />
                    </font>
                </Label>
                <!-- account created text-->
                <Label alignment="CENTER" text="Your account has been created."
                       textAlignment="CENTER" textFill="#b3b3b3" wrapText="true">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <!-- close button -->
                <Button maxWidth="70" prefHeight="30" prefWidth="25"
                        style="-fx-background-color: #f5a64b; -fx-background-radius: 10; -fx-cursor: hand;"
                        text="Close" textFill="#121212" onAction="#CloseAnnouncement">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Button>
            </children>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </children>
</HBox>