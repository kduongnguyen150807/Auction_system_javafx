<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" stylesheets="@/css/biddingform/BiddingForm.css" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.ui.BiddingForm.BiddingFormController" fx:id="RootPane">
    <children>
        <VBox styleClass="BackGround" maxWidth="653" maxHeight="400" prefHeight="400" prefWidth="653" spacing="20">
            <children>
                <HBox spacing="20">
                    <children>
                        <VBox spacing="10">
                            <children>
                                <Label text="ITEM NUMBER" styleClass="AboveLabel"/>
                                <Label fx:id="ItemId" text="#ID" styleClass="GoldenText" minWidth="200"/>
                            </children>
                        </VBox>
                        <VBox spacing="10">
                            <children>
                                <Label text="ITEM NAME" styleClass="AboveLabel" />
                                <Label fx:id="ItemName" text="Item Name" styleClass="GoldenText" prefWidth="400"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <VBox spacing="10">
                    <children>
                        <Label text="ENTER YOUR AMOUNT" styleClass="AboveLabel" />
                        <TextField fx:id="BidAmount" promptText="0.00$" styleClass="GoldenText, ProGoldenText" prefWidth="400" prefHeight="100"/>
                    </children>
                </VBox>
                <HBox spacing="20">
                    <children>
                        <Hyperlink fx:id="CancelBidding" text="Cancel" styleClass="AboveLabel, HyperSubText" onAction="#RemoveForm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="ConfirmBidding" text="Confirm" styleClass="btn-primary" prefHeight="50" prefWidth="150" onAction="#RemoveForm"/>
                    </children>
                </HBox>
            </children>
            <padding><Insets left="20" right="20" top="20"/></padding>
        </VBox>
    </children>
</VBox>
