<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
            maxWidth="Infinity" maxHeight="Infinity"
            fx:controller="com.auction.client.ui.Profile.ProfileController"
            stylesheets="@/css/profile/Profile.css">
    <content>
        <VBox spacing="18" styleClass="profile-root">
            <children>
                <HBox spacing="14" alignment="CENTER_LEFT" styleClass="profile-header">
                    <children>
                        <StackPane prefWidth="88" minWidth="88" maxWidth="88" prefHeight="88" alignment="CENTER">
                            <children>
                                <Circle radius="34" styleClass="profile-avatar"/>
                            </children>
                        </StackPane>
                        <VBox spacing="4">
                            <children>
                                <Label fx:id="usernameLabel" text="username" styleClass="profile-title"/>
                                <Label text="Description" styleClass="profile-subtitle"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="8" alignment="TOP_RIGHT">
                            <children>
                                <Button fx:id="editButton" text="Edit Profile" styleClass="profile-btn" onAction="#handleEditProfile"/>
                                <Button text="Log Out" styleClass="logout-btn" onAction="#handleLogout"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="14">
                    <children>
                        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card" spacing="8" alignment="CENTER_LEFT">
                            <children>
                                <Label text="MONEY SPENT" styleClass="metric-title"/>
                                <Label text="0$" styleClass="metric-value"/>
                            </children>
                            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card" spacing="8" alignment="CENTER_LEFT">
                            <children>
                                <Label text="ITEMS SOLD" styleClass="metric-title"/>
                                <Label text="0" styleClass="metric-value"/>
                            </children>
                            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <Label text="Personal Information" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Current role:" styleClass="field-label"/>
                        <Label fx:id="roleLabel" text="Bidder" styleClass="pill-value"/>
                        <Button fx:id="toggleRoleButton" text="Switch to Seller" styleClass="profile-btn" onAction="#handleToggleRole"/>
                    </children>
                </HBox>
                <HBox spacing="14">
                    <children>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="FULL NAME" styleClass="field-label"/>
                                <Label fx:id="fullNameLabel" text="username" styleClass="field-box"/>
                                <TextField fx:id="fullNameInput" text="username" styleClass="field-input" visible="false" managed="false"/>
                            </children>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                                <Label fx:id="emailLabel" text="username@mail.com" styleClass="field-box"/>
                                <TextField fx:id="emailInput" text="username@mail.com" styleClass="field-input" visible="false" managed="false"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <VBox spacing="8">
                    <children>
                        <Label text="PHONE NUMBER" styleClass="field-label"/>
                        <Label fx:id="phoneLabel" text="N/A" styleClass="field-box"/>
                        <TextField fx:id="phoneInput" text="N/A" styleClass="field-input" visible="false" managed="false"/>
                    </children>
                </VBox>
            </children>
            <padding><Insets top="26" right="24" bottom="24" left="24"/></padding>
        </VBox>
    </content>
</ScrollPane>
